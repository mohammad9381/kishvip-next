# ===================================
# تنظیمات دیتابیس (MySQL)
# ===================================
DB_HOST=localhost
DB_USER=next
DB_PASS=nextpassworddb
DB_DATABASE=nextdb
DB_PORT=3370

# ===================================
# درگاه پرداخت زیبال
# ===================================
REACT_APP_ZIBAL_MERCHENT=your_zibal_merchant_id

# ===================================
# کاوه‌نگار (ارسال پیامک)
# ===================================
REACT_APP_KAVE_API_KEY=your_kavenegar_api_key

# ===================================
# پنل 2Rist (سرویس گردشگری)
# ===================================
NEXT_PUBLIC_2RIST_PUBLIC=your_2rist_public_key
NEXT_PUBLIC_2RIST_PRIVATE=your_2rist_private_key
NEXT_PUBLIC_2RIST_URL=https://api.2ristpanel.com/v1

# ===================================
# URL سرور فعلی (برای SSR fetch)
# ===================================
REACT_APP_API_URL=http://localhost:7654

# ===================================
# Google Analytics
# ===================================
NEXT_PUBLIC_GOOGLE_ANALYTICS=GA_MEASUREMENT_ID

# ===================================
# رمز JWT (باید رشته طولانی و تصادفی باشد)
# ===================================
SECRET_JWT=change_this_to_a_random_secret_string
